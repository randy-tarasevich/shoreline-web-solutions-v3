---
// src/components/home/ServiceRow.astro
// A single service row. Rendered four times on the homepage.
//
// Usage:
//   <ServiceRow
//     number="01"
//     headline="Get Found.<br>Get Chosen."
//     copy="A custom-built website engineered to rank on Google..."
//     linkText="Web Development"
//     linkUrl="/services/custom-web-development"
//   />

interface Props {
  number: string;
  headline: string;
  copy: string;
  linkText: string;
  linkUrl: string;
}

const { number, headline, copy, linkText, linkUrl } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-[70px_1fr] gap-3 md:gap-8 items-start py-8 md:py-10 border-b border-brand-border reveal">
  <!-- Number -->
  <span class="font-display text-2xl md:text-5xl text-brand-dim opacity-30 leading-none">
    {number}
  </span>

  <!-- Content: headline left, copy right -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-12 items-start">
    <h2 class="font-display text-[clamp(1.8rem,3vw,2.4rem)] leading-[1.15] text-brand-text" set:html={headline} />

    <div class="flex flex-col gap-4">
      <p class="text-base text-brand-muted leading-relaxed">
        {copy}
      </p>
      <a
        href={linkUrl}
        class="inline-flex items-center gap-2 text-brand-accent font-semibold text-sm hover:gap-3 transition-all"
      >
        {linkText}<span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</div>
