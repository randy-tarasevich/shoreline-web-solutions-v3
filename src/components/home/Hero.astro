---
// src/components/home/Hero.astro
// Homepage hero section. Contains the only <h1> on the page.
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-5 pt-32 pb-24 overflow-hidden"
  aria-label="Introduction"
>
  <!-- Background glow -->
  <div
    class="absolute top-[-15%] left-1/2 -translate-x-1/2 w-full max-w-[900px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(13,148,136,0.06) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-3xl mx-auto">
    <h1 class="font-display text-[clamp(2.8rem,6.5vw,5.5rem)] leading-[1.08] tracking-tight text-brand-text text-balance mb-6 reveal">
      Your Website Should Be Your Best Salesperson
    </h1>

    <p class="text-[clamp(1.05rem,2vw,1.25rem)] text-brand-muted leading-relaxed max-w-xl mx-auto mb-10 reveal reveal-d1">
      We build custom digital systems that bring Connecticut businesses more customers, more revenue, and less busywork.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-d2">
      <a
        href="/audit"
        class="px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5"
      >
        Audit Your Website Free
      </a>
      <a
        href="/portfolio"
        class="px-8 py-4 bg-transparent border border-brand-border hover:border-brand-dim text-brand-muted hover:text-brand-text font-semibold text-[0.95rem] rounded-xl transition-all"
      >
        See Our Work
      </a>
    </div>
  </div>
</section>
