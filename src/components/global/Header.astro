---
// src/components/global/Header.astro
// Fixed navigation bar with backdrop blur.
// Services opens a submenu (desktop: hover/focus; mobile: disclosure).
//
// Usage (inside a page, passed to Layout slot):
//   <Header slot="header" />

const serviceSubmenu = [
  { label: "All services", href: "/services" },
  { label: "Custom Web Development", href: "/services/custom-web-development" },
  { label: "Custom Applications", href: "/services/custom-application-development" },
  { label: "Automation", href: "/services/automation-solutions" },
  { label: "SEO & Performance", href: "/services/seo-performance-optimization" },
];

const navLinks = [
  { label: "About", href: "/about" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;

const isServicesActive =
  currentPath === "/services" || currentPath.startsWith("/services/");

function linkActive(href: string) {
  if (href === "/services") return isServicesActive;
  return currentPath === href || currentPath.startsWith(href + "/");
}

function subLinkActive(href: string) {
  if (href === "/services") {
    return currentPath === "/services" || currentPath === "/services/";
  }
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-brand-base/70 backdrop-blur-xl border-b border-brand-border/40"
>
  <div class="max-w-6xl mx-auto px-5 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-body font-bold text-lg text-brand-text tracking-tight">
      Shoreline Web Solutions
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      <a
        href="/about"
        class:list={[
          "text-sm font-medium transition-colors",
          linkActive("/about") ? "text-brand-text" : "text-brand-muted hover:text-brand-text",
        ]}
      >
        About
      </a>

      <!-- Services + dropdown -->
      <div class="relative group/subnav">
        <a
          href="/services"
          class:list={[
            "text-sm font-medium transition-colors inline-flex items-center gap-1",
            isServicesActive ? "text-brand-text" : "text-brand-muted hover:text-brand-text",
          ]}
          aria-haspopup="true"
        >
          Services
          <svg class="w-3.5 h-3.5 opacity-70" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <div
          class="absolute left-0 top-full z-60 pt-2 w-56 opacity-0 invisible translate-y-1 transition-all duration-200 ease-out pointer-events-none group-hover/subnav:opacity-100 group-hover/subnav:visible group-hover/subnav:translate-y-0 group-hover/subnav:pointer-events-auto group-focus-within/subnav:opacity-100 group-focus-within/subnav:visible group-focus-within/subnav:translate-y-0 group-focus-within/subnav:pointer-events-auto"
          role="menu"
          aria-label="Services"
        >
          <div
            class="rounded-xl border border-brand-border/80 bg-brand-base/95 backdrop-blur-xl shadow-lg py-2"
          >
            {serviceSubmenu.map(({ label, href }) => (
              <a
                href={href}
                role="menuitem"
                class:list={[
                  "block px-4 py-2.5 text-sm transition-colors",
                  subLinkActive(href)
                    ? "text-brand-text bg-brand-surface/80"
                    : "text-brand-muted hover:text-brand-text hover:bg-brand-surface/50",
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>

      {navLinks.slice(1).map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "text-sm font-medium transition-colors",
            linkActive(href) ? "text-brand-text" : "text-brand-muted hover:text-brand-text",
          ]}
        >
          {label}
        </a>
      ))}

      <a
        href="/audit"
        class="text-sm font-semibold bg-brand-accent hover:bg-brand-accent-light text-white px-5 py-2 rounded-lg transition-colors"
      >
        Free Audit
      </a>
    </nav>

    <!-- Mobile menu: dual SVG (avoids broken CSS transforms on three spans in some mobile browsers) -->
    <button
      type="button"
      id="menu-toggle"
      class="md:hidden relative flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-lg text-brand-text transition-colors hover:bg-brand-surface/50"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="menu-icon-hamburger"
        class="pointer-events-none absolute size-6 text-current transition-opacity duration-300 ease-out"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M5 7h14M5 12h14M5 17h14" />
      </svg>
      <svg
        id="menu-icon-close"
        class="pointer-events-none absolute size-6 text-current opacity-0 transition-opacity duration-300 ease-out"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden max-h-[min(70vh,calc(100dvh-4rem))] overflow-y-auto border-t border-brand-border/40 bg-brand-base/95 backdrop-blur-xl"
    aria-label="Mobile navigation"
  >
    <div class="px-5 py-6 flex flex-col gap-1">
      <a
        href="/about"
        class:list={[
          "text-base font-medium py-2 transition-colors",
          linkActive("/about") ? "text-brand-text" : "text-brand-muted hover:text-brand-text",
        ]}
      >
        About
      </a>

      <details class="group/mobile-subnav">
        <summary
          class:list={[
            "list-none cursor-pointer text-base font-medium py-2 flex items-center justify-between gap-2 transition-colors [&::-webkit-details-marker]:hidden",
            isServicesActive ? "text-brand-text" : "text-brand-muted",
          ]}
        >
          <span>Services</span>
          <svg
            class="w-4 h-4 opacity-70 shrink-0 transition-transform group-open/mobile-subnav:rotate-180"
            viewBox="0 0 12 12"
            fill="none"
            aria-hidden="true"
          >
            <path d="M2.5 4.5 6 8l3.5-3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          </svg>
        </summary>
        <div class="mt-1 mb-2 ml-1 pl-4 border-l border-brand-border/60 flex flex-col gap-0.5">
          {serviceSubmenu.map(({ label, href }) => (
            <a
              href={href}
              class:list={[
                "text-sm py-2 transition-colors",
                subLinkActive(href) ? "text-brand-text font-medium" : "text-brand-dim hover:text-brand-muted",
              ]}
            >
              {label}
            </a>
          ))}
        </div>
      </details>

      {navLinks.slice(1).map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "text-base font-medium py-2 transition-colors",
            linkActive(href) ? "text-brand-text" : "text-brand-muted hover:text-brand-text",
          ]}
        >
          {label}
        </a>
      ))}

      <a
        href="/audit"
        class="mt-3 text-center text-sm font-semibold bg-brand-accent hover:bg-brand-accent-light text-white px-5 py-3 rounded-lg transition-colors"
      >
        Free Audit
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("menu-icon-hamburger");
  const iconClose = document.getElementById("menu-icon-close");

  let open = false;

  toggle?.addEventListener("click", () => {
    open = !open;
    menu?.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");

    iconMenu?.classList.toggle("opacity-0", open);
    iconClose?.classList.toggle("opacity-0", !open);
  });
</script>
