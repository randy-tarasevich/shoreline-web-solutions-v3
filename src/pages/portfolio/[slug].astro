---
// src/pages/portfolio/[slug].astro
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://shorelinewebsolutions.com/" },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://shorelinewebsolutions.com/portfolio" },
    { "@type": "ListItem", "position": 3, "name": project.data.title, "item": `https://shorelinewebsolutions.com/portfolio/${project.data.slug}` }
  ]
};
---

<Layout
  title={`${project.data.title} | Portfolio | Shoreline Web Solutions`}
  description={project.data.description}
  schema={breadcrumbSchema}
>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-5 pt-28 pb-4" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-brand-dim">
      <li><a href="/" class="hover:text-brand-muted transition-colors">Home</a></li>
      <li aria-hidden="true">→</li>
      <li><a href="/portfolio" class="hover:text-brand-muted transition-colors">Portfolio</a></li>
      <li aria-hidden="true">→</li>
      <li class="text-brand-muted">{project.data.title}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-5 pt-8 pb-12" aria-label="Project overview">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
      Case Study
    </p>
    <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] leading-[1.1] text-brand-text text-balance mb-6 reveal reveal-d1">
      {project.data.title}
    </h1>
    <p class="text-[clamp(1.05rem,2vw,1.2rem)] text-brand-muted leading-relaxed max-w-2xl mb-6 reveal reveal-d2">
      {project.data.description}
    </p>

    <!-- Tech + link -->
    <div class="flex flex-wrap items-center gap-4 reveal reveal-d3">
      <div class="flex flex-wrap gap-2">
        {project.data.technologies.map((tech) => (
          <span class="text-xs font-medium text-brand-dim bg-brand-surface px-3 py-1 rounded-full border border-brand-border">
            {tech}
          </span>
        ))}
      </div>
      {project.data.url && (
        <a
          href={project.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-brand-accent font-semibold text-sm hover:gap-3 transition-all"
        >
          Visit Site<span aria-hidden="true">↗</span>
        </a>
      )}
    </div>
  </section>

  <!-- Content -->
  <article class="max-w-4xl mx-auto px-5 pb-20 reveal">
    <div class="prose-shoreline">
      <Content />
    </div>
  </article>

  <!-- CTA -->
  <section class="py-20 border-t border-brand-border text-center" aria-label="Get started">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="font-display text-[clamp(1.8rem,3.5vw,2.5rem)] text-brand-text leading-tight mb-4 reveal">
        Want Results Like These?
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mx-auto mb-8 reveal reveal-d1">
        Every project starts with a conversation about your business. Tell us what you're trying to achieve.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-d2">
        <a href="/contact" class="px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold rounded-xl transition-all hover:-translate-y-0.5">
          Start a Conversation
        </a>
        <a href="/portfolio" class="px-8 py-4 bg-transparent border border-brand-border hover:border-brand-dim text-brand-muted hover:text-brand-text font-semibold rounded-xl transition-all">
          View All Projects
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
