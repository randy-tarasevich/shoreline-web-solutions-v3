---
// src/pages/services/custom-web-development.astro
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

// Get the service content
const allServices = await getCollection('services');
const service = allServices.find(s => s.data.slug === 'custom-web-development');

if (!service) {
  return Astro.redirect('/services');
}

const { Content } = await render(service);

// ── Page-specific structured data ─────────────────────────
const serviceSchema = {
  "@type": "Service",
  "name": "Custom Web Development",
  "description": service.data.metaDescription,
  "provider": {
    "@id": "https://shorelinewebsolutions.com/#localbusiness"
  },
  "areaServed": [
    { "@type": "State", "name": "Connecticut" },
    { "@type": "Country", "name": "US" }
  ],
  "serviceType": "Web Development"
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://shorelinewebsolutions.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://shorelinewebsolutions.com/services"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Custom Web Development",
      "item": "https://shorelinewebsolutions.com/services/custom-web-development"
    }
  ]
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does a custom website take to build?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most small business sites are completed in 3 to 6 weeks. Projects with custom functionality like booking systems or portals may take longer. We give you a clear timeline before we start."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a custom website cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every project is scoped individually based on what your business needs. A typical small business site starts in the $2,000 to $4,000 range. We provide a detailed proposal with no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "Will my site be optimized for Google?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every site includes on-page SEO fundamentals: optimized title tags, meta descriptions, structured data, fast load times, and mobile responsiveness. For local businesses, we also optimize your Google Business Profile."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after launch?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer maintenance plans to keep your site updated, secure, and performing. We also monitor your Google Search Console data and recommend improvements as your business grows."
      }
    },
    {
      "@type": "Question",
      "name": "Do I own my website?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You own the code, the design, and the content. It's hosted on your account and you have full access to everything. No lock-in, no proprietary platforms."
      }
    }
  ]
};
---

<Layout
  title={service.data.metaTitle}
  description={service.data.metaDescription}
  ogImage="/images/og-web-development.jpg"
  schema={[serviceSchema, breadcrumbSchema, faqSchema]}
>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-5 pt-28 pb-4" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-brand-dim">
      <li><a href="/" class="hover:text-brand-muted transition-colors">Home</a></li>
      <li aria-hidden="true">→</li>
      <li><a href="/services" class="hover:text-brand-muted transition-colors">Services</a></li>
      <li aria-hidden="true">→</li>
      <li class="text-brand-muted">Custom Web Development</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-5 pt-8 pb-16" aria-label="Service overview">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
      Web Development
    </p>
    <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] leading-[1.1] text-brand-text text-balance mb-6 reveal reveal-d1">
      {service.data.headline}
    </h1>
    <p class="text-[clamp(1.05rem,2vw,1.2rem)] text-brand-muted leading-relaxed max-w-2xl reveal reveal-d2">
      {service.data.subhead}
    </p>
  </section>

  <!-- Content from markdown -->
  <article class="max-w-4xl mx-auto px-5 pb-20 reveal">
    <div class="prose-shoreline">
      <Content />
    </div>
  </article>

  <!-- CTA -->
  <section class="py-20 border-t border-brand-border text-center" aria-label="Get started">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="font-display text-[clamp(1.8rem,3.5vw,2.5rem)] text-brand-text leading-tight mb-4 reveal">
        Let's Grow Your Business
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mx-auto mb-8 reveal reveal-d1">
        Tell us about your business and what you're looking to achieve. We'll put together a plan that makes sense for your goals and budget.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-d2">
        <a href="/contact" class="px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold rounded-xl transition-all hover:-translate-y-0.5">
          Start a Conversation
        </a>
        <a href="/audit" class="px-8 py-4 bg-transparent border border-brand-border hover:border-brand-dim text-brand-muted hover:text-brand-text font-semibold rounded-xl transition-all">
          Audit Your Current Site
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
