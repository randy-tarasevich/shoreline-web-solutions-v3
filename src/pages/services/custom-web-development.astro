---
// src/pages/services/custom-web-development.astro

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const seo = {
  title: "Custom Web Development | Shoreline Web Solutions",
  description: "Hand-coded websites built to rank on Google, load fast, and convert visitors into customers. Serving Connecticut small businesses.",
  canonical: "https://shorelinewebsolutions.com/services/custom-web-development",
};

const deliverables = [
  "Custom-coded in Astro.js — no WordPress, no Wix, no drag-and-drop limitations",
  "Sub-2-second load times on mobile and desktop",
  "Structured data and technical SEO built in from day one",
  "Core Web Vitals optimized to meet Google's performance thresholds",
  "Responsive design tested across real devices",
  "Cloudflare Pages deployment for global speed and 99.9% uptime",
  "Google Analytics 4 and Search Console integration",
  "Ongoing support and iteration after launch",
];

const serviceSchema = {
  "@type": "Service",
  "name": "Custom Web Development",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Shoreline Web Solutions",
    "url": "https://shorelinewebsolutions.com"
  },
  "description": "Hand-coded custom websites built for performance, SEO, and conversion. No templates. Built from scratch for Connecticut small businesses.",
  "areaServed": "Connecticut",
  "serviceType": "Web Development"
};
---

<Layout title={seo.title} description={seo.description} canonical={seo.canonical} schema={serviceSchema}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="pt-40 pb-20 px-5" aria-label="Service introduction">
    <div class="max-w-6xl mx-auto">
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-brand-dim text-sm hover:text-brand-muted transition-colors mb-10 reveal"
      >
        ← All Services
      </a>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
        Custom Web Development
      </p>
      <h1 class="font-display text-[clamp(2.6rem,6vw,5rem)] leading-[1.06] tracking-tight text-brand-text text-balance max-w-3xl mb-6 reveal reveal-d1">
        Built to Convert.<br />Built to Last.
      </h1>
      <p class="text-[clamp(1rem,1.8vw,1.2rem)] text-brand-muted leading-relaxed max-w-xl reveal reveal-d2">
        Most websites look fine and do nothing. Yours should be your hardest-working salesperson — ranking on Google, loading before your competitor's even starts, and turning visitors into customers without you lifting a finger.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- The Problem -->
  <section class="py-20 px-5" aria-label="The problem with template sites">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-5 reveal">
          Template Sites Are Costing You Business
        </h2>
        <p class="text-brand-muted leading-relaxed mb-4 reveal reveal-d1">
          Squarespace, Wix, and WordPress themes ship bloated, slow, and built for the average business — not yours. They load every feature you'll never use, fight Google's performance standards, and look like a thousand other sites in your industry.
        </p>
        <p class="text-brand-muted leading-relaxed reveal reveal-d2">
          When a potential customer searches for what you do, Google ranks the fastest, most relevant, most technically sound site. Template platforms aren't built to win that race.
        </p>
      </div>
      <div class="reveal reveal-d1">
        <div class="border border-brand-border rounded-2xl p-8 bg-brand-surface">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-6">By the Numbers</p>
          <div class="flex flex-col gap-6">
            <div class="border-l-2 border-brand-accent pl-5">
              <p class="font-display text-3xl text-brand-text mb-1">53%</p>
              <p class="text-brand-dim text-sm leading-snug">of mobile users leave a site that takes longer than 3 seconds to load</p>
            </div>
            <div class="border-l-2 border-brand-accent pl-5">
              <p class="font-display text-3xl text-brand-text mb-1">75%</p>
              <p class="text-brand-dim text-sm leading-snug">of users judge a business's credibility based on its website design</p>
            </div>
            <div class="border-l-2 border-brand-accent pl-5">
              <p class="font-display text-3xl text-brand-text mb-1">#1</p>
              <p class="text-brand-dim text-sm leading-snug">page on Google captures 27x more clicks than page 2</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- What You Get -->
  <section class="py-20 px-5" aria-label="What is included">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-3 reveal">
        What's Included
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mb-12 reveal reveal-d1">
        Every custom web project ships with the same performance and SEO foundation. No nickel-and-diming for the basics.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        {deliverables.map((item, i) => (
          <div class={`flex items-start gap-4 p-5 rounded-xl border border-brand-border hover:border-brand-dim transition-colors reveal reveal-d${(i % 3) + 1}`}>
            <span class="text-brand-accent text-lg leading-none shrink-0 mt-0.5" aria-hidden="true">✦</span>
            <p class="text-brand-muted text-[0.95rem] leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- Who It's For -->
  <section class="py-20 px-5" aria-label="Who this service is for">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-5 reveal">
          Who This Is For
        </h2>
        <div class="flex flex-col gap-4">
          {[
            "Service businesses that rely on local search to find new clients",
            "Established businesses whose current site is embarrassing compared to their actual quality",
            "Owners who've outgrown their DIY site and need something that performs",
            "Businesses launching something new and want to do it right the first time",
          ].map((item, i) => (
            <div class={`flex items-start gap-3 reveal reveal-d${i + 1}`}>
              <span class="text-brand-accent shrink-0 mt-1" aria-hidden="true">→</span>
              <p class="text-brand-muted leading-relaxed text-[0.95rem]">{item}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="reveal reveal-d2">
        <div class="border border-brand-border rounded-2xl p-8 bg-brand-surface">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-4">Not Sure If This Is You?</p>
          <p class="text-brand-muted leading-relaxed text-[0.95rem] mb-6">
            Run a free audit on your current site. In 60 seconds you'll see your performance score, SEO gaps, and exactly what's costing you customers.
          </p>
          <a
            href="/audit"
            class="inline-block px-6 py-3 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.9rem] rounded-xl transition-all hover:-translate-y-0.5"
          >
            Audit My Website Free
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center px-5 bg-brand-surface" aria-label="Get started">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.4rem)] text-brand-text leading-tight mb-4 reveal">
        Ready to Build Something That Works?
      </h2>
      <p class="text-brand-muted leading-relaxed mb-8 reveal reveal-d1">
        Tell us about your business and what you need. We'll come back with an honest assessment and a clear plan — no jargon, no pressure.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5 reveal reveal-d2"
      >
        Start the Conversation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>