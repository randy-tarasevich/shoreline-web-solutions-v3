---
// src/pages/services/automation-solutions.astro

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const seo = {
  title: "Automation Solutions | Shoreline Web Solutions",
  description: "Business automation for Connecticut small businesses. Connect your tools, eliminate manual work, and reclaim hours every week.",
  canonical: "https://shorelinewebsolutions.com/services/automation-solutions",
};

const deliverables = [
  "Workflow audit to identify your highest-value automation opportunities",
  "Custom automation pipelines connecting your existing tools",
  "Lead capture and follow-up sequences that run without you",
  "Automated reporting — the numbers you need, delivered on schedule",
  "Form-to-CRM and email integration setup",
  "Review request and reputation management automation",
  "Notification and alert systems for your team",
  "Documentation so you understand and control what runs",
];

const serviceSchema = {
  "@type": "Service",
  "name": "Automation Solutions",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Shoreline Web Solutions",
    "url": "https://shorelinewebsolutions.com"
  },
  "description": "Business process automation for small businesses. Connect tools, eliminate manual steps, and reclaim hours every week.",
  "areaServed": "Connecticut",
  "serviceType": "Business Automation"
};
---

<Layout title={seo.title} description={seo.description} canonical={seo.canonical} schema={serviceSchema}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="pt-40 pb-20 px-5" aria-label="Service introduction">
    <div class="max-w-6xl mx-auto">
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-brand-dim text-sm hover:text-brand-muted transition-colors mb-10 reveal"
      >
        ← All Services
      </a>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
        Automation Solutions
      </p>
      <h1 class="font-display text-[clamp(2.6rem,6vw,5rem)] leading-[1.06] tracking-tight text-brand-text text-balance max-w-3xl mb-6 reveal reveal-d1">
        Do More.<br />Touch Less.
      </h1>
      <p class="text-[clamp(1rem,1.8vw,1.2rem)] text-brand-muted leading-relaxed max-w-xl reveal reveal-d2">
        Every hour you spend on repetitive tasks is an hour you're not spending on the work that actually grows your business. We build the systems that handle the busywork — so you don't have to.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- The Problem -->
  <section class="py-20 px-5" aria-label="The cost of manual work">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-5 reveal">
          Manual Work Is Expensive — Even When It's Free
        </h2>
        <p class="text-brand-muted leading-relaxed mb-4 reveal reveal-d1">
          Copying data between systems. Sending follow-up emails by hand. Pulling reports every Monday morning. Responding to every new lead within five minutes or losing them. These tasks aren't free — they cost you time, attention, and consistency.
        </p>
        <p class="text-brand-muted leading-relaxed reveal reveal-d2">
          Automation doesn't replace you. It handles the predictable so you can focus on the unpredictable — the relationships, the decisions, and the work that actually requires a human.
        </p>
      </div>
      <div class="reveal reveal-d1">
        <div class="border border-brand-border rounded-2xl p-8 bg-brand-surface">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-6">Where We Find Time</p>
          <div class="flex flex-col gap-5">
            {[
              { task: "Lead follow-up", save: "3–5 hrs/week" },
              { task: "Appointment reminders", save: "2–3 hrs/week" },
              { task: "Weekly reporting", save: "2–4 hrs/week" },
              { task: "Review requests", save: "1–2 hrs/week" },
              { task: "Data entry between tools", save: "4–6 hrs/week" },
            ].map(({ task, save }) => (
              <div class="flex items-center justify-between border-b border-brand-border pb-4 last:border-0 last:pb-0">
                <p class="text-brand-muted text-sm">{task}</p>
                <p class="text-brand-accent text-sm font-semibold">{save}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- What You Get -->
  <section class="py-20 px-5" aria-label="What is included">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-3 reveal">
        What's Included
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mb-12 reveal reveal-d1">
        We start by understanding your current workflow before recommending anything. Every automation is built to match how you actually operate.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        {deliverables.map((item, i) => (
          <div class={`flex items-start gap-4 p-5 rounded-xl border border-brand-border hover:border-brand-dim transition-colors reveal reveal-d${(i % 3) + 1}`}>
            <span class="text-brand-accent text-lg leading-none shrink-0 mt-0.5" aria-hidden="true">✦</span>
            <p class="text-brand-muted text-[0.95rem] leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- Who It's For -->
  <section class="py-20 px-5" aria-label="Who this service is for">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-10 reveal">
        Who This Is For
      </h2>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          "Business owners doing things manually that a computer could handle in seconds",
          "Teams that lose leads because follow-up is inconsistent or too slow",
          "Service businesses that want more Google reviews but hate asking for them",
          "Anyone spending time every week on a task that happens the exact same way every time",
        ].map((item, i) => (
          <div class={`flex items-start gap-4 p-5 rounded-xl border border-brand-border reveal reveal-d${i + 1}`}>
            <span class="text-brand-accent shrink-0 mt-1" aria-hidden="true">→</span>
            <p class="text-brand-muted leading-relaxed text-[0.95rem]">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center px-5 bg-brand-surface" aria-label="Get started">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.4rem)] text-brand-text leading-tight mb-4 reveal">
        What Would You Do With 10 Extra Hours a Week?
      </h2>
      <p class="text-brand-muted leading-relaxed mb-8 reveal reveal-d1">
        Tell us where you're losing time. We'll show you what can be automated and what it would actually save you.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5 reveal reveal-d2"
      >
        Start the Conversation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
