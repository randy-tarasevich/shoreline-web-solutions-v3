---
// src/pages/services/seo-performance-optimization.astro

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const seo = {
  title: "SEO & Performance Optimization | Shoreline Web Solutions",
  description: "Technical SEO and Core Web Vitals optimization for Connecticut small businesses. Get found on Google and keep visitors once they arrive.",
  canonical: "https://shorelinewebsolutions.com/services/seo-performance-optimization",
};

const deliverables = [
  "Full technical SEO audit — crawlability, indexing, structured data, meta hierarchy",
  "Core Web Vitals optimization: LCP, FCP, TBT, CLS brought up to Google's thresholds",
  "Local SEO setup — Google Business Profile, NAP consistency, local citations",
  "Structured data (JSON-LD) implementation for rich search results",
  "On-page optimization — H1/H2 hierarchy, meta titles, descriptions, canonical tags",
  "Image compression, lazy loading, and next-gen format conversion",
  "Google Analytics 4 and Search Console setup and verification",
  "Monthly performance report with rankings, traffic, and Core Web Vitals trends",
];

const serviceSchema = {
  "@type": "Service",
  "name": "SEO & Performance Optimization",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Shoreline Web Solutions",
    "url": "https://shorelinewebsolutions.com"
  },
  "description": "Technical SEO and Core Web Vitals optimization. Get found on Google and keep visitors once they arrive.",
  "areaServed": "Connecticut",
  "serviceType": "Search Engine Optimization"
};
---

<Layout title={seo.title} description={seo.description} canonical={seo.canonical} schema={serviceSchema}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="pt-40 pb-20 px-5" aria-label="Service introduction">
    <div class="max-w-6xl mx-auto">
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-brand-dim text-sm hover:text-brand-muted transition-colors mb-10 reveal"
      >
        ← All Services
      </a>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
        SEO & Performance Optimization
      </p>
      <h1 class="font-display text-[clamp(2.6rem,6vw,5rem)] leading-[1.06] tracking-tight text-brand-text text-balance max-w-3xl mb-6 reveal reveal-d1">
        Get Found. Get Chosen.<br />Get Ahead.
      </h1>
      <p class="text-[clamp(1rem,1.8vw,1.2rem)] text-brand-muted leading-relaxed max-w-xl reveal reveal-d2">
        Ranking on Google isn't luck and it's not magic. It's technical precision — fast load times, clean code, structured data, and content that answers exactly what your customers are searching for.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- The Problem -->
  <section class="py-20 px-5" aria-label="Why most sites don't rank">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-5 reveal">
          Being Good at What You Do Doesn't Get You Found
        </h2>
        <p class="text-brand-muted leading-relaxed mb-4 reveal reveal-d1">
          Google doesn't rank businesses based on quality. It ranks them based on technical signals — page speed, structured data, relevance, authority, and user experience. A mediocre business with a technically excellent site will outrank you every time if your site sends the wrong signals.
        </p>
        <p class="text-brand-muted leading-relaxed reveal reveal-d2">
          Most small business sites were built by someone who knew design but not SEO, or by the owner themselves using a template. The result: invisible on Google, slow on mobile, and hemorrhaging potential customers to competitors who just happened to get the technical stuff right.
        </p>
      </div>
      <div class="reveal reveal-d1">
        <div class="border border-brand-border rounded-2xl p-8 bg-brand-surface">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-6">What Google Actually Measures</p>
          <div class="flex flex-col gap-5">
            {[
              { metric: "Largest Contentful Paint (LCP)", target: "Under 2.5s", icon: "⚡" },
              { metric: "First Contentful Paint (FCP)", target: "Under 1.8s", icon: "⚡" },
              { metric: "Total Blocking Time (TBT)", target: "Under 200ms", icon: "⚡" },
              { metric: "Cumulative Layout Shift (CLS)", target: "Under 0.1", icon: "⚡" },
              { metric: "Structured Data", target: "7+ items detected", icon: "🗂" },
            ].map(({ metric, target, icon }) => (
              <div class="flex items-center justify-between border-b border-brand-border pb-4 last:border-0 last:pb-0">
                <p class="text-brand-muted text-sm">{metric}</p>
                <p class="text-brand-accent text-sm font-semibold">{target}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- What You Get -->
  <section class="py-20 px-5" aria-label="What is included">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-3 reveal">
        What's Included
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mb-12 reveal reveal-d1">
        We start with a full audit of your current site before recommending a single change. No guessing. No generic advice.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        {deliverables.map((item, i) => (
          <div class={`flex items-start gap-4 p-5 rounded-xl border border-brand-border hover:border-brand-dim transition-colors reveal reveal-d${(i % 3) + 1}`}>
            <span class="text-brand-accent text-lg leading-none shrink-0 mt-0.5" aria-hidden="true">✦</span>
            <p class="text-brand-muted text-[0.95rem] leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- Audit Callout -->
  <section class="py-20 px-5" aria-label="Free website audit">
    <div class="max-w-6xl mx-auto">
      <div class="border border-brand-accent/30 rounded-2xl p-10 md:p-14 bg-brand-surface text-center reveal">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-4">Free First Step</p>
        <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-4">
          See Exactly Where Your Site Stands
        </h2>
        <p class="text-brand-muted leading-relaxed max-w-lg mx-auto mb-8">
          Run a free audit on your current site and get your PageSpeed score, Core Web Vitals, SEO gaps, and structured data status in 60 seconds. No email required.
        </p>
        <a
          href="/audit"
          class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5"
        >
          Audit My Website Free
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- Who It's For -->
  <section class="py-20 px-5" aria-label="Who this service is for">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-10 reveal">
        Who This Is For
      </h2>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          "Businesses that rely on local search but aren't showing up on Google Maps or Page 1",
          "Sites that load slowly on mobile and are losing visitors before they even see the content",
          "Business owners who've been told they need SEO but don't know where to start",
          "Companies that had SEO work done years ago and haven't looked at it since",
        ].map((item, i) => (
          <div class={`flex items-start gap-4 p-5 rounded-xl border border-brand-border reveal reveal-d${i + 1}`}>
            <span class="text-brand-accent shrink-0 mt-1" aria-hidden="true">→</span>
            <p class="text-brand-muted leading-relaxed text-[0.95rem]">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center px-5 bg-brand-surface" aria-label="Get started">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.4rem)] text-brand-text leading-tight mb-4 reveal">
        Ready to Stop Being Invisible on Google?
      </h2>
      <p class="text-brand-muted leading-relaxed mb-8 reveal reveal-d1">
        Tell us about your business and where you're falling short on search. We'll audit your site and come back with a clear, prioritized plan.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5 reveal reveal-d2"
      >
        Start the Conversation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
