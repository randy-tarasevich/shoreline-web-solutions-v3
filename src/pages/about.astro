---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
---

<Layout
  title="About | Shoreline Web Solutions | Old Lyme, CT"
  description="Shoreline Web Solutions is a custom web development studio in Old Lyme, Connecticut helping small businesses grow online with hand-coded websites, e-commerce stores, and AI-powered tools."
>
  <Header slot="header" />

  <section class="min-h-screen flex items-center justify-center pt-24">
    <div class="text-center px-5">
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-4">Coming Soon</p>
      <h1 class="font-display text-4xl text-brand-text mb-4">About</h1>
      <p class="text-brand-muted">This page is under construction.</p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
