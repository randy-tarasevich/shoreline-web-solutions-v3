---
// src/pages/portfolio.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://shorelinewebsolutions.com/" },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://shorelinewebsolutions.com/portfolio" }
  ]
};
---

<Layout
  title="Portfolio | Shoreline Web Solutions | Old Lyme, CT"
  description="Case studies and project highlights from Shoreline Web Solutions. Custom websites, e-commerce stores, and AI-powered tools built for small businesses."
  schema={breadcrumbSchema}
>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-5 pt-28 pb-4" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-brand-dim">
      <li><a href="/" class="hover:text-brand-muted transition-colors">Home</a></li>
      <li aria-hidden="true">→</li>
      <li class="text-brand-muted">Portfolio</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-5 pt-8 pb-16" aria-label="Portfolio">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
      Portfolio
    </p>
    <h1 class="font-display text-[clamp(2.2rem,5vw,3.5rem)] leading-[1.1] text-brand-text text-balance mb-6 reveal reveal-d1">
      Real Projects. Real Results.
    </h1>
    <p class="text-[clamp(1.05rem,2vw,1.2rem)] text-brand-muted leading-relaxed max-w-2xl reveal reveal-d2">
      Every project here started with a business problem — not a design brief. Here's how we solved them.
    </p>
  </section>

  <!-- Project list -->
  <section class="max-w-4xl mx-auto px-5 pb-20">
    <div class="border-t border-brand-border">
      {sorted.map((project, i) => (
        <a
          href={`/portfolio/${project.data.slug}`}
          class="block group py-10 border-b border-brand-border reveal"
        >
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-12">
            <div>
              <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] leading-tight text-brand-text group-hover:text-brand-accent transition-colors mb-3">
                {project.data.title}
              </h2>
              <p class="text-brand-muted leading-relaxed mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.data.technologies.map((tech) => (
                  <span class="text-xs font-medium text-brand-dim bg-brand-surface px-3 py-1 rounded-full border border-brand-border">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
            <div class="flex items-center lg:justify-end">
              <span class="inline-flex items-center gap-2 text-brand-accent font-semibold text-sm group-hover:gap-3 transition-all">
                View Case Study<span aria-hidden="true">→</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-brand-border text-center" aria-label="Get started">
    <div class="max-w-4xl mx-auto px-5">
      <h2 class="font-display text-[clamp(1.8rem,3.5vw,2.5rem)] text-brand-text leading-tight mb-4 reveal">
        Want Results Like These?
      </h2>
      <p class="text-brand-muted leading-relaxed max-w-lg mx-auto mb-8 reveal reveal-d1">
        Every project starts with a conversation about your business. Let's figure out what growth looks like for you.
      </p>
      <a href="/contact" class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold rounded-xl transition-all hover:-translate-y-0.5 reveal reveal-d2">
        Start a Conversation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
