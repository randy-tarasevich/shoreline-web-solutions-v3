---
// src/pages/portfolio.astro

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const seo = {
  title: "Portfolio | Shoreline Web Solutions",
  description: "Real projects. Real results. Case studies from Shoreline Web Solutions — custom web development, performance optimization, and automation for Connecticut small businesses.",
  canonical: "https://shorelinewebsolutions.com/portfolio",
};

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://shorelinewebsolutions.com" },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://shorelinewebsolutions.com/portfolio" },
  ]
};
---

<Layout title={seo.title} description={seo.description} canonical={seo.canonical} schema={breadcrumbSchema}>
  <Header slot="header" />

  <!-- Page Header -->
  <section class="pt-40 pb-16 px-5" aria-label="Portfolio introduction">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent mb-5 reveal">
        Portfolio
      </p>
      <h1 class="font-display text-[clamp(2.4rem,5.5vw,4.5rem)] leading-[1.08] tracking-tight text-brand-text text-balance max-w-2xl mb-6 reveal reveal-d1">
        Real Projects.<br />Real Results.
      </h1>
      <p class="text-[clamp(1rem,1.8vw,1.15rem)] text-brand-muted leading-relaxed max-w-xl reveal reveal-d2">
        Every project here started with a business problem — not a design brief. Here's how we solved them.
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-5">
    <hr class="border-brand-border" />
  </div>

  <!-- Project List -->
  <section class="px-5 py-4" aria-label="Case studies">
    <div class="max-w-6xl mx-auto">
      {sorted.map((project, i) => (
        <a
          href={`/portfolio/${project.data.slug}`}
          class="group flex flex-col md:flex-row md:items-center gap-6 md:gap-12 py-14 border-b border-brand-border hover:border-brand-dim transition-colors reveal"
          aria-label={`View case study for ${project.data.title}`}
        >
          <!-- Number -->
          <span class="font-display text-[clamp(2rem,3vw,2.8rem)] text-brand-border group-hover:text-brand-accent transition-colors leading-none shrink-0 w-16">
            0{i + 1}
          </span>

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <h2 class="font-display text-[clamp(1.5rem,2.8vw,2.2rem)] text-brand-text leading-tight mb-2 group-hover:text-white transition-colors">
              {project.data.title}
            </h2>
            {(project.data.client || project.data.location) && (
              <p class="text-sm text-brand-dim mb-3">
                {project.data.client && <span>{project.data.client}</span>}
                {project.data.client && project.data.location && (
                  <span class="text-brand-border mx-1.5" aria-hidden="true">·</span>
                )}
                {project.data.location && <span>{project.data.location}</span>}
              </p>
            )}
            <p class="text-brand-muted leading-relaxed text-[0.95rem] max-w-lg mb-4">
              {project.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.data.technologies.map((tech) => (
                <span class="text-xs font-medium text-brand-dim bg-brand-surface px-3 py-1 rounded-full border border-brand-border">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Arrow -->
          <span
            class="text-brand-dim text-2xl shrink-0 group-hover:text-brand-accent group-hover:translate-x-1 transition-all"
            aria-hidden="true"
          >
            →
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-24 text-center px-5" aria-label="Work with us">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-[clamp(1.6rem,3vw,2.2rem)] text-brand-text leading-tight mb-4 reveal">
        Want Results Like These?
      </h2>
      <p class="text-brand-muted leading-relaxed mb-8 reveal reveal-d1">
        Tell us about your business. We'll tell you honestly what we can do and what it would take.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-4 bg-brand-accent hover:bg-brand-accent-light text-white font-semibold text-[0.95rem] rounded-xl transition-all hover:-translate-y-0.5 reveal reveal-d2"
      >
        Start the Conversation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>